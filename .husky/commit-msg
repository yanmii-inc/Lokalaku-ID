#!/bin/sh

# ── 1. Conventional Commits format ───────────────────────────────────────────
pnpm exec commitlint --edit "$1"

# ── 2. Traceability footers — required only for behavioral commit types ───────
# Doc impact follows the commit TYPE, not the diff size:
#   feat | fix | perf        → behavioral / user-visible → MUST trace to a REQ/ADR/issue
#   refactor | style | chore → internal / non-behavioral → footer optional (exempt here)
#   test | ci | docs | revert → no behavioral weight      → exempt
TYPE=$(head -1 "$1" | sed -n 's/^\([a-z]*\).*/\1/p')

case "$TYPE" in
  feat|fix|perf) ;;   # fall through to enforcement
  *) exit 0 ;;        # all other types are exempt
esac

COMMIT_MSG=$(cat "$1")

if printf '%s' "$COMMIT_MSG" | grep -qE '^(Implements|See|Closes|Refs):'; then
  exit 0
fi

# No footer found on a feat/fix/perf — block and explain.
STAGED=$(git diff --cached --name-only \
  | grep -E '^(apps/|packages/|docker/|scripts/|compose\.yaml|.*Dockerfile$|\.github/workflows/)')

echo ""
echo "┌─────────────────────────────────────────────────────────────────┐"
echo "│  LOKALAKU: '$TYPE' commit is missing traceability footers"
echo "└─────────────────────────────────────────────────────────────────┘"
echo ""
if [ -n "$STAGED" ]; then
  echo "  Files staged:"
  printf '%s\n' "$STAGED" | head -5 | sed 's/^/    /'
  EXTRA=$(printf '%s\n' "$STAGED" | wc -l | tr -d ' ')
  [ "$EXTRA" -gt 5 ] && echo "    ... and $((EXTRA - 5)) more"
  echo ""
fi
echo "  A '$TYPE' commit carries behavioral weight and must include at least one:"
echo ""
echo "    Implements: REQ-XX-NNN     — satisfies a product requirement (PRD.md)"
echo "    Implements: REQ-INFRA-NNN  — satisfies an infra requirement (docs/infra/REQUIREMENTS.md)"
echo "    See: ADR-NNN               — references an architecture decision"
echo "    Closes: #NNN               — resolves a GitHub issue / task"
echo "    Refs: #NNN                 — related issue (not closing)"
echo ""
echo "  → Run /reconcile in Claude Code to back-fill docs and get the footers."
echo "  → Genuinely no requirement (rare for feat/fix/perf)? Bypass: git commit --no-verify"
echo ""
exit 1
